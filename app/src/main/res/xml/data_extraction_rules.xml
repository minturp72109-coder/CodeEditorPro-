<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for the production build.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude temporary database journal/WAL files -->
        <exclude domain="database" path="code_editor_database-journal"/>
        <exclude domain="database" path="code_editor_database-shm"/>
        <exclude domain="database" path="code_editor_database-wal"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude temporary database journal/WAL files -->
        <exclude domain="database" path="code_editor_database-journal"/>
        <exclude domain="database" path="code_editor_database-shm"/>
        <exclude domain="database" path="code_editor_database-wal"/>
    </device-transfer>
</data-extraction-rules>
